<ScrollView
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:id="@+id/main_layout"
  android:layout_width="match_parent"
  android:layout_height="match_parent">
  <androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="5dp">
    <androidx.constraintlayout.widget.Guideline
      android:id="@+id/guideline_v05"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      app:layout_constraintGuide_percent="0.05" />
    <androidx.constraintlayout.widget.Guideline
      android:id="@+id/guideline_v95"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      app:layout_constraintGuide_percent="0.95" />

    <androidx.appcompat.widget.AppCompatTextView
      android:id="@+id/label_size"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="@string/file_size"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toTopOf="parent"
      android:layout_marginStart="5dp"
      android:layout_marginTop="10dp"
      style="@style/AppTheme.InputLabel"/>

    <androidx.appcompat.widget.AppCompatTextView
      android:id="@+id/text_size"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintStart_toEndOf="@id/label_size"
      android:layout_marginStart="5dp"
      android:layout_marginEnd="5dp"
      android:layout_marginTop="10dp"
      style="@style/AppTheme.InputLabel"/>

    <androidx.appcompat.widget.AppCompatTextView
      android:id="@+id/label_size_part"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="@string/size_opening_part"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@id/text_size"
      android:layout_marginStart="5dp"
      android:layout_marginTop="10dp"
      style="@style/AppTheme.InputLabel"/>

    <androidx.appcompat.widget.AppCompatTextView
      android:id="@+id/text_size_part"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toBottomOf="@id/text_size"
      app:layout_constraintStart_toEndOf="@id/label_size_part"
      android:layout_marginStart="5dp"
      android:layout_marginEnd="5dp"
      android:layout_marginTop="10dp"
      style="@style/AppTheme.InputLabel"/>

    <androidx.appcompat.widget.AppCompatTextView
      android:id="@+id/label_unit"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toBottomOf="@id/text_size_part"
      app:layout_constraintStart_toStartOf="parent"
      android:layout_marginStart="5dp"
      android:layout_marginEnd="5dp"
      android:layout_marginTop="15dp"
      android:text="@string/unit"
      style="@style/AppTheme.InputLabel"/>
    <androidx.appcompat.widget.AppCompatSpinner
      android:id="@+id/sp_unit"
      android:layout_marginTop="15dp"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toBottomOf="@id/text_size_part"
      app:layout_constraintStart_toEndOf="@id/label_unit" />

    <androidx.appcompat.widget.AppCompatTextView
      android:id="@+id/label_input_type"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toBottomOf="@id/label_unit"
      app:layout_constraintStart_toStartOf="parent"
      android:layout_marginStart="5dp"
      android:layout_marginEnd="5dp"
      android:layout_marginTop="15dp"
      android:text="@string/input_type"
      style="@style/AppTheme.InputLabel"/>
    <androidx.appcompat.widget.AppCompatSpinner
      android:id="@+id/sp_input_type"
      android:layout_marginTop="15dp"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toBottomOf="@id/label_unit"
      app:layout_constraintStart_toEndOf="@id/label_input_type" />

    <androidx.appcompat.widget.AppCompatTextView
      android:id="@+id/label_description"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toBottomOf="@id/label_input_type"
      app:layout_constraintStart_toEndOf="@id/guideline_v05"
      app:layout_constraintEnd_toStartOf="@id/guideline_v95"
      android:layout_marginStart="5dp"
      android:layout_marginEnd="5dp"
      android:layout_marginTop="15dp"
      android:singleLine="false"
      android:text="@string/partial_file_opening_description"
      style="@style/AppTheme.InputLabel"/>
    <com.google.android.material.textfield.TextInputLayout
      android:id="@+id/til_start"
      android:layout_marginStart="5dp"
      android:layout_marginEnd="5dp"
      android:layout_marginTop="15dp"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      app:errorEnabled="true"
      app:layout_constraintTop_toBottomOf="@id/label_description"
      app:layout_constraintStart_toStartOf="parent">

      <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/tiet_start"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/start_offset"
        android:text="@string/zero"
        android:gravity="start"
        android:textAlignment="gravity"
        android:inputType="number"
        android:fontFamily="@font/jetbrains_mono"
        android:digits=" 0123456789."
        android:singleLine="true" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
      android:id="@+id/til_end"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginStart="5dp"
      android:layout_marginEnd="5dp"
      android:layout_marginTop="15dp"
      app:errorEnabled="true"
      app:layout_constraintTop_toBottomOf="@id/til_start"
      app:layout_constraintStart_toStartOf="parent">

      <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/tiet_end"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="start"
        android:textAlignment="gravity"
        android:hint="@string/end_offset"
        android:text="@string/zero"
        android:fontFamily="@font/jetbrains_mono"
        android:inputType="number"
        android:digits=" 0123456789."
        android:singleLine="true" />
    </com.google.android.material.textfield.TextInputLayout>

  </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>