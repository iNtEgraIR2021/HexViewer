<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:id="@+id/main_layout"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:paddingStart="10dp"
  android:paddingEnd="10dp"
  android:orientation="vertical"
  >
  <RelativeLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatTextView
      android:id="@+id/tv_label_source"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_alignParentStart="true"
      android:layout_alignParentTop="true"
      android:layout_toStartOf="@+id/iv_visibility_source"
      android:text="@string/source"
      style="@style/AppTheme.InputLabel"/>
    <ImageView
      android:id="@+id/iv_visibility_source"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:src="@drawable/ic_expand_less"
      android:contentDescription="@null"
      android:layout_alignParentTop="true"
      android:layout_alignParentEnd="true"/>
  </RelativeLayout>
  <LinearLayout
    android:id="@+id/ll_source"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="0.25"
    android:orientation="vertical"
    android:layoutDirection="ltr">

    <LinearLayout
      android:id="@+id/title_source"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="horizontal">

      <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/title_line_numbers_source"
        android:gravity="center_vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@null"
        android:textSize="@dimen/activity_line_update_lv_text_size"
        android:fontFamily="@font/jetbrains_mono"
        android:paddingEnd="5dp"
        android:paddingStart="2dp"/>
      <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/title_content_source"
        android:textColor="@color/colorNumbers"
        android:gravity="center_vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_content8"
        android:textSize="@dimen/activity_line_update_lv_text_size"
        android:fontFamily="@font/jetbrains_mono" />
    </LinearLayout>

    <ListView
      android:id="@+id/lv_source"
      android:layout_width="match_parent"
      android:layout_height="match_parent"/>
  </LinearLayout>

  <RelativeLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatTextView
      android:id="@+id/tv_label_result"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_alignParentStart="true"
      android:layout_alignParentTop="true"
      android:layout_toStartOf="@+id/iv_visibility_result"
      android:text="@string/result"
      style="@style/AppTheme.InputLabel" />
    <ImageView
      android:id="@+id/iv_visibility_result"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:src="@drawable/ic_expand_less"
      android:contentDescription="@null"
      android:layout_alignParentTop="true"
      android:layout_alignParentEnd="true"/>
  </RelativeLayout>
  <LinearLayout
    android:id="@+id/ll_result"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="0.25"
    android:orientation="vertical"
    android:layoutDirection="ltr">

    <LinearLayout
      android:id="@+id/title_result"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="horizontal">

      <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/title_line_numbers_result"
        android:gravity="center_vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@null"
        android:textSize="@dimen/activity_line_update_lv_text_size"
        android:fontFamily="@font/jetbrains_mono"
        android:paddingEnd="5dp"
        android:paddingStart="2dp"/>
      <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/title_content_result"
        android:textColor="@color/colorNumbers"
        android:gravity="center_vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_content8"
        android:textSize="@dimen/activity_line_update_lv_text_size"
        android:fontFamily="@font/jetbrains_mono" />
    </LinearLayout>

    <ListView
      android:id="@+id/lv_result"
      android:layout_width="match_parent"
      android:layout_height="match_parent"/>
  </LinearLayout>

  <androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="0.5"
    android:orientation="vertical">
    <androidx.constraintlayout.widget.Guideline
      android:id="@+id/guideline_v50"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      app:layout_constraintGuide_percent="0.50" />
    <View
      android:id="@+id/padding_10"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toTopOf="parent"
      android:layout_width="match_parent"
      android:layout_height="5dp"/>

    <androidx.appcompat.widget.AppCompatCheckBox
      android:id="@+id/chk_smart_input"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@id/padding_10"
      app:layout_constraintEnd_toStartOf="@id/guideline_v50"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:text="@string/smart_input"/>
    <androidx.appcompat.widget.AppCompatCheckBox
      android:id="@+id/chk_overwrite"
      app:layout_constraintStart_toStartOf="@id/guideline_v50"
      app:layout_constraintTop_toBottomOf="@id/padding_10"
      app:layout_constraintEnd_toEndOf="parent"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:text="@string/overwrite"/>

    <androidx.appcompat.widget.AppCompatTextView
      android:id="@+id/tv_label"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/update_hint_hex"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@id/chk_smart_input"
      style="@style/AppTheme.InputLabel"  />

    <com.google.android.material.textfield.TextInputLayout
      android:id="@+id/til_input_hex"
      android:layout_width="match_parent"
      android:layout_height="0dp"
      app:helperTextTextColor="@color/colorAccent"
      app:helperTextEnabled="true"
      app:errorEnabled="true"
      app:errorTextAppearance="@style/AppTheme.ErrorTextAppearance"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@id/tv_label"
      app:layout_constraintBottom_toBottomOf="parent"
      app:hintEnabled="false">

      <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/et_input_hex"
        android:hint="@null"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="@dimen/activity_line_update_lv_text_size"
        android:importantForAutofill="no"
        android:inputType="textVisiblePassword|textMultiLine"
        android:fontFamily="@font/jetbrains_mono"
        android:gravity="top"
        android:scrollbars="vertical"
        android:textDirection="ltr"/>
    </com.google.android.material.textfield.TextInputLayout>
  </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>